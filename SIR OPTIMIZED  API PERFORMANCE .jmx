        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="4,6_SAVE &amp; SAVE AS DRAFT : SIR REQUEST" enabled="false">
          <stringProp name="HTTPSampler.domain">${API_BASE}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/api/warehouse_app/stockRequest/save</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">	{&#xd;
    &quot;mode&quot;: &quot;UI&quot;,&#xd;
    &quot;stockStatus&quot;: &quot;active&quot;,&#xd;
    &quot;requestType&quot;: &quot;StockIn&quot;,&#xd;
    &quot;requestFrom&quot;: {&#xd;
        &quot;branchType&quot;: &quot;Warehouse&quot;,&#xd;
        &quot;warehouseId&quot;: &quot;65ee85d021efb6a7300c93e7&quot;,&#xd;
        &quot;warehouseName&quot;: &quot;Annur ss main warehouse&quot;&#xd;
    },&#xd;
    &quot;priorityStatus&quot;: &quot;Normal&quot;,&#xd;
    &quot;requestProducts&quot;: [&#xd;
        {&#xd;
            &quot;productCategoryId&quot;: &quot;675c4a29108eb4204037ee16&quot;,&#xd;
            &quot;masterProductId&quot;: &quot;696480026faea6aceedcfb81&quot;,&#xd;
            &quot;inventoryType&quot;: &quot;Product&quot;,&#xd;
